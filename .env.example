# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=lenido-booking@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# Make.com webhook (triggers WhatsApp via ManyChat)
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_id

# Host contact
HOST_WHATSAPP_NUMBER=2348012345678

# iCal URLs from Airbnb / Booking.com (one per property)
ICAL_URL_LEKKI_01=https://www.airbnb.com/calendar/ical/your_listing_id.ics
ICAL_URL_LEKKI_02=https://www.airbnb.com/calendar/ical/your_listing_id.ics

# Sanity CMS
SANITY_PROJECT_ID=your_sanity_project_id_here
SANITY_DATASET=production
# Optional: set this in Sanity dashboard as a webhook secret so cache clears on publish
REVALIDATE_SECRET=a_random_secret_string_you_choose

# Server
PORT=3000
NODE_ENV=production
